{
  "name": "fine-translate",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "0.3.0",
  "publisher": "FineSoft",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/GaKireiTsuki/vscode-translate.git"
  },
  "bugs": {
    "url": "https://github.com/GaKireiTsuki/vscode-translate/issues"
  },
  "homepage": "https://github.com/GaKireiTsuki/vscode-translate#readme",
  "qna": "https://github.com/GaKireiTsuki/vscode-translate/issues",
  "keywords": [
    "translate",
    "translation",
    "translator",
    "i18n",
    "openai",
    "claude",
    "anthropic",
    "gemini",
    "deepseek",
    "kimi",
    "moonshot",
    "qwen",
    "ollama",
    "grok",
    "xai",
    "groq",
    "mistral",
    "deepl",
    "youdao",
    "baidu",
    "llm",
    "翻译"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Education"
  ],
  "main": "./dist/extension.js",
  "l10n": "./l10n",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "fine-translate.selection",
        "title": "%command.selection.title%"
      },
      {
        "command": "fine-translate.toggleHover",
        "title": "%command.toggleHover.title%"
      },
      {
        "command": "fine-translate.setApiKey",
        "title": "%command.setApiKey.title%"
      },
      {
        "command": "fine-translate.clearApiKey",
        "title": "%command.clearApiKey.title%"
      },
      {
        "command": "fine-translate.clearCache",
        "title": "%command.clearCache.title%"
      },
      {
        "command": "fine-translate.showUsagePanel",
        "title": "%command.showUsagePanel.title%"
      },
      {
        "command": "fine-translate.resetStats",
        "title": "%command.resetStats.title%"
      },
      {
        "command": "fine-translate.switchProvider",
        "title": "%command.switchProvider.title%"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "fine-translate.selection",
          "when": "editorHasSelection",
          "group": "1_modification"
        }
      ]
    },
    "keybindings": [
      {
        "command": "fine-translate.selection",
        "key": "ctrl+shift+t",
        "mac": "cmd+shift+t",
        "when": "editorTextFocus && editorHasSelection"
      }
    ],
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "fine-translate.activeProvider": {
          "type": "string",
          "default": "openai",
          "enum": [
            "openai",
            "anthropic",
            "gemini",
            "xai",
            "deepseek",
            "moonshot",
            "zhipu",
            "qwen",
            "mistral",
            "cohere",
            "groq",
            "together",
            "fireworks",
            "deepinfra",
            "cerebras",
            "huggingface",
            "baseten",
            "ollama",
            "deepl",
            "youdao",
            "baidu"
          ],
          "enumDescriptions": [
            "OpenAI · gpt-4o-mini",
            "Anthropic (Claude) · claude-sonnet-4-5",
            "Google Gemini · gemini-2.5-flash",
            "xAI (Grok) · grok-3-mini",
            "DeepSeek · deepseek-chat",
            "Moonshot (Kimi) · kimi-k2.5",
            "Zhipu (智谱 GLM) · glm-4-flash",
            "Alibaba Qwen (DashScope) · qwen-plus",
            "Mistral · mistral-small-latest",
            "Cohere · command-r",
            "Groq · llama-3.3-70b-versatile",
            "Together AI · meta-llama/Meta-Llama-3.3-70B-Instruct-Turbo",
            "Fireworks · accounts/fireworks/models/llama-v3p3-70b-instruct",
            "DeepInfra · meta-llama/Llama-3.3-70B-Instruct",
            "Cerebras · llama3.3-70b",
            "Hugging Face Inference · meta-llama/Llama-3.1-8B-Instruct",
            "Baseten · Qwen/Qwen3-235B-A22B-Instruct-2507",
            "Ollama (local) · llama3.2",
            "%config.activeProvider.enum.deepl%",
            "%config.activeProvider.enum.youdao%",
            "%config.activeProvider.enum.baidu%"
          ],
          "markdownDescription": "%config.activeProvider.markdownDescription%"
        },
        "fine-translate.providers.openai.baseUrl": {
          "type": "string",
          "default": "",
          "enum": [
            "",
            "https://api.openai.com/v1",
            "https://api.anthropic.com/v1",
            "https://generativelanguage.googleapis.com/v1beta/openai",
            "https://api.x.ai/v1",
