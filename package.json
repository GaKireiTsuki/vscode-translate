          ],
          "markdownDescription": "%config.openai.model.markdownDescription%"
        },
        "fine-translate.providers.openai.systemPrompt": {
          "type": "string",
          "default": "You are a precise translator. Output only the translation, no explanation.",
          "description": "%config.openai.systemPrompt.description%"
        },
        "fine-translate.providers.openai.apiKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "%config.openai.apiKey.markdownDescription%"
        },
        "fine-translate.providers.deepl.useFreeApi": {
          "type": "boolean",
          "default": true,
          "description": "%config.deepl.useFreeApi.description%"
        },
        "fine-translate.providers.deepl.apiKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "%config.deepl.apiKey.markdownDescription%"
        },
        "fine-translate.providers.baidu.appId": {
          "type": "string",
          "default": "",
          "description": "%config.baidu.appId.description%"
        },
        "fine-translate.providers.baidu.appSecret": {
          "type": "string",
          "default": "",
          "markdownDescription": "%config.baidu.appSecret.markdownDescription%"
        },
        "fine-translate.providers.youdao.appKey": {
          "type": "string",
          "default": "",
          "description": "%config.youdao.appKey.description%"
        },
        "fine-translate.providers.youdao.appSecret": {
          "type": "string",
          "default": "",
          "markdownDescription": "%config.youdao.appSecret.markdownDescription%"
        },
        "fine-translate.targetLanguage": {
          "type": "string",
          "default": "",
          "description": "%config.targetLanguage.description%"
        },
        "fine-translate.hover.enabled": {
          "type": "boolean",
          "default": false,
          "description": "%config.hover.enabled.description%"
        },
        "fine-translate.hover.debounceMs": {
          "type": "number",
          "default": 400,
          "minimum": 100,
          "maximum": 2000,
          "description": "%config.hover.debounceMs.description%"
        },
        "fine-translate.hover.languages": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "*"
          ],
          "description": "%config.hover.languages.description%"
        },
        "fine-translate.selection.autoOnSelect": {
          "type": "boolean",
          "default": false,
          "description": "%config.selection.autoOnSelect.description%"
        },
        "fine-translate.cache.maxEntries": {
          "type": "number",
          "default": 500,
          "minimum": 0,
          "description": "%config.cache.maxEntries.description%"
        },
        "fine-translate.cache.ttlMinutes": {
          "type": "number",
          "default": 1440,
          "minimum": 1,
          "description": "%config.cache.ttlMinutes.description%"
        },
        "fine-translate.maxCharsPerRequest": {
          "type": "number",
          "default": 4000,
          "minimum": 1,
          "description": "%config.maxCharsPerRequest.description%"
        },
        "fine-translate.telemetry.estimateCost": {
          "type": "boolean",
          "default": true,
          "description": "%config.telemetry.estimateCost.description%"
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "compile": "tsc -p ./",
    "sync-schema": "node scripts/sync-schema.mjs",
    "package": "pnpm run sync-schema && vsce package",
    "test:unit": "vitest run",
    "test:e2e": "tsc -p ./ && node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.3.0",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.20.0",
    "glob": "^13.0.6",
    "mocha": "^11.7.5",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
